# Local/private settings for dv term-llm hub hooks.
# Copy to .env and fill in. .env is intentionally ignored by git.

# Full URL to your term-llm Hub, including any base path.
TERM_LLM_HUB_URL="http://example.local:12654/hub/"

# 1Password op-cache reference for the Hub registration token.
TERM_LLM_HUB_REGISTRATION_TOKEN_OP="op://Vault/Item/field"

# Optional: host term-llm binary to copy into containers.
# TERM_LLM_BIN="$HOME/Source/term-llm/term-llm"
