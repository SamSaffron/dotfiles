#!/usr/bin/env bash
# shellcheck disable=SC2329 # notifier functions are invoked indirectly via $notifier.

# Small, dependency-light countdown used before delayed screenshots.
#
# The old version used PyGObject/GTK3 and xrandr, which is fragile on Wayland
# and fails completely if the Python GTK bindings are not installed.  This
# version only requires a shell for timing, and shows the countdown through the
# first available lightweight notification mechanism:
#   1. dunstify       - best fit here because dunst is started by the configs
#   2. notify-send    - generic libnotify fallback
#   3. hyprctl notify - Hyprland built-in fallback
# If none of those are available, it still sleeps for the requested time and
# exits successfully so the screenshot command chained with `&&` still runs.

set -u

usage() {
    printf 'Usage: %s [seconds] [message]\n' "${0##*/}" >&2
}

seconds="${1:-3}"
message="${2:-Screenshot}"

if [[ ! "$seconds" =~ ^[0-9]+$ ]]; then
    usage
    exit 2
fi

# A zero second countdown is valid and useful in scripts.
if (( seconds == 0 )); then
    exit 0
fi

notify_with_dunstify() {
    local remaining="$1"
    dunstify \
        --replace=91190 \
        --timeout=950 \
        --urgency=low \
        "$message in $remaining" \
        >/dev/null 2>&1
}

notify_with_notify_send() {
    local remaining="$1"
    # Keep this fallback conservative: older notify-send builds may not support
    # replacement IDs, but -t/-u are widely available.
    notify-send \
        -t 950 \
        -u low \
        "$message in $remaining" \
        >/dev/null 2>&1
}

notify_with_hyprctl() {
    local remaining="$1"
    hyprctl notify -1 950 'rgb(fab387)' "$message in $remaining" >/dev/null 2>&1
}

notify_with_terminal() {
    local remaining="$1"
    # Only write to stdout when this was run from a terminal. Keybind invocations
    # should stay silent.
    if [[ -t 1 ]]; then
        printf '\r%s in %s… ' "$message" "$remaining"
    fi
}

notifier='notify_with_terminal'
if command -v dunstify >/dev/null 2>&1; then
    notifier='notify_with_dunstify'
elif command -v notify-send >/dev/null 2>&1; then
    notifier='notify_with_notify_send'
elif [[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]] && command -v hyprctl >/dev/null 2>&1; then
    notifier='notify_with_hyprctl'
fi

for (( remaining = seconds; remaining > 0; remaining-- )); do
    "$notifier" "$remaining" || true
    sleep 1
done

if [[ -t 1 ]]; then
    printf '\n'
fi

exit 0
