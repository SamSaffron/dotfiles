#!/usr/bin/env bash
# Usage:
#   name-workspace                 reset the current workspace to just its id
#   name-workspace some name       set the current workspace to "<id> some name"

set -euo pipefail

id="$(hyprctl activeworkspace -j | jq -r '.id')"

if ! [[ "$id" =~ ^[0-9]+$ ]]; then
    echo "error: could not determine active workspace id (got: $id)" >&2
    exit 1
fi

if (( $# > 0 )); then
    name="$id: $*"
else
    name="$id"
fi

# Hyprland 0.55+ uses Lua dispatch syntax when running a Lua config.
# `hyprctl dispatch` wraps its argument in `hl.dispatch(...)`, so pass a
# dispatcher expression instead of the old `renameworkspace <id> <name>` form.
lua_name="$(printf '%s' "$name" | jq -Rs .)"
hyprctl dispatch "hl.dsp.workspace.rename({ workspace = $id, name = $lua_name })"
